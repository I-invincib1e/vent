NODE_ENV=development

# Database (Turso/libSQL)
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# AI Gateway (LLM)
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=

# Deepgram (real-time speech-to-text)
DEEPGRAM_API_KEY=

# ElevenLabs (real-time text-to-speech)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Public HTTPS URL Twilio can reach (wss derived automatically for the media stream)
PUBLIC_APP_URL=

# Optional — default webhook target for n8n/Zapier/Make call-event notifications
WEBHOOK_URL=

# Object storage (Tigris/S3-compatible), if using file uploads
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Legacy bootstrap admin key — always accepted alongside labeled admin keys, never removed
ADMIN_API_KEY=

# Optional — Redis-backed session storage for running more than one instance.
# Leave unset to keep the default in-memory session store (zero behavior change).
REDIS_URL=
